# Test 4: Pattern A {- A -} A (emit first A, exclude second consecutive A, emit third A)
query TDI
SELECT * FROM stock_price
MATCH_RECOGNIZE (
    PARTITION BY company
    ORDER BY price_date
    ALL ROWS PER MATCH
    PATTERN (A ({- A -}) A)
    DEFINE
        A AS price < 135
)
----
DDOG 2024-01-01 125
DDOG 2024-01-03 132
