query TDIIIIII
SELECT * FROM stock_price
MATCH_RECOGNIZE (
    PARTITION BY company
    ORDER BY price_date
    MEASURES
        FIRST(B.price) AS first_price,
        LAST(B.price) AS last_price,
        COUNT(*) AS count,
        MATCH_NUMBER() AS match_number,
        MATCH_SEQUENCE_NUMBER() AS match_sequence_number
    ALL ROWS PER MATCH
    PATTERN (ANY ({- B -}+) ANY)
    DEFINE
        B AS price > 140
)
ORDER BY company
