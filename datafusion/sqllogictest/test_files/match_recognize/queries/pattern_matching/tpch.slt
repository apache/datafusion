EXPLAIN ANALYZE
SELECT l_orderkey, cnt
FROM (
    SELECT *
    FROM lineitem
    MATCH_RECOGNIZE (
    PARTITION BY l_orderkey
    ORDER BY l_linenumber
    MEASURES COUNT(A.l_quantity) AS cnt
    PATTERN ((A B){2,4} C)
    DEFINE
        A AS l_quantity < 5,
        B AS l_quantity BETWEEN 5 AND 10,
        C AS l_quantity > 10
    )
) sub
