# Test complex MEASURES expressions
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    MEASURES
        COUNT(*) AS match_count,
        SUM(price) AS total_price,
        AVG(price) AS avg_price,
        price * 2 AS double_price
    PATTERN (A)
    DEFINE A AS price > 100
)
