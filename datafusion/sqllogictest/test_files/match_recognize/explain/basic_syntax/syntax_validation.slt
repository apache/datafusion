# Test MATCH_RECOGNIZE function structure
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    PARTITION BY company
    ORDER BY price_date
    MEASURES COUNT(*) AS cnt
    ONE ROW PER MATCH
    AFTER MATCH SKIP TO NEXT ROW
    PATTERN (A+)
    DEFINE A AS price > 100
)
----
logical_plan
01)Projection: stock_price.company, count(CASE WHEN __mr_classifier != Utf8("(empty)") THEN Int64(1) ELSE NULL END) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING AS cnt
02)--Filter: __mr_is_last_match_row
03)----Projection: stock_price.company, __mr_is_last_match_row, count(CASE WHEN __mr_classifier != Utf8("(empty)") THEN Int64(1) ELSE NULL END) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING
04)------WindowAggr: windowExpr=[[count(CASE WHEN __mr_classifier != Utf8("(empty)") THEN Int64(1) ELSE Int64(NULL) END) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING AS count(CASE WHEN __mr_classifier != Utf8("(empty)") THEN Int64(1) ELSE NULL END) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING]]
05)--------Projection: stock_price.company, stock_price.price_date, __mr_classifier, __mr_match_number, __mr_is_last_match_row
06)----------MatchRecognizePattern: partition_by=[stock_price.company] order_by=[stock_price.price_date ASC NULLS LAST] after_skip=TO_NEXT_ROW pattern=[A+]
07)------------Projection: stock_price.company, stock_price.price_date, stock_price.price, stock_price.price > Int32(100) AS __mr_symbol_A
08)--------------TableScan: stock_price projection=[company, price_date, price]
physical_plan
01)ProjectionExec: expr=[company@0 as company, count(CASE WHEN __mr_classifier != Utf8("(empty)") THEN Int64(1) ELSE NULL END) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING@1 as cnt], schema=[company:Utf8View;N, cnt:Int64]
02)--CoalesceBatchesExec: target_batch_size=8192, schema=[company:Utf8View;N, count(CASE WHEN __mr_classifier != Utf8("(empty)") THEN Int64(1) ELSE NULL END) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING:Int64]
03)----FilterExec: __mr_is_last_match_row@1, projection=[company@0, count(CASE WHEN __mr_classifier != Utf8("(empty)") THEN Int64(1) ELSE NULL END) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING@2], schema=[company:Utf8View;N, count(CASE WHEN __mr_classifier != Utf8("(empty)") THEN Int64(1) ELSE NULL END) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING:Int64]
04)------ProjectionExec: expr=[company@0 as company, __mr_is_last_match_row@4 as __mr_is_last_match_row, count(CASE WHEN __mr_classifier != Utf8("(empty)") THEN Int64(1) ELSE NULL END) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING@5 as count(CASE WHEN __mr_classifier != Utf8("(empty)") THEN Int64(1) ELSE NULL END) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING], schema=[company:Utf8View;N, __mr_is_last_match_row:Boolean, count(CASE WHEN __mr_classifier != Utf8("(empty)") THEN Int64(1) ELSE NULL END) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING:Int64]
05)--------WindowAggExec: wdw=[count(CASE WHEN __mr_classifier != Utf8("(empty)") THEN Int64(1) ELSE NULL END) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING: Ok(Field { name: "count(CASE WHEN __mr_classifier != Utf8(\"(empty)\") THEN Int64(1) ELSE NULL END) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING", data_type: Int64, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} }), frame: WindowFrame { units: Rows, start_bound: Preceding(UInt64(NULL)), end_bound: Following(UInt64(NULL)), is_causal: false }], schema=[company:Utf8View;N, price_date:Date32;N, __mr_classifier:Utf8, __mr_match_number:UInt64, __mr_is_last_match_row:Boolean, count(CASE WHEN __mr_classifier != Utf8("(empty)") THEN Int64(1) ELSE NULL END) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING:Int64]
06)----------SortExec: expr=[company@0 ASC NULLS LAST, __mr_match_number@3 ASC NULLS LAST, price_date@1 ASC NULLS LAST], preserve_partitioning=[true], schema=[company:Utf8View;N, price_date:Date32;N, __mr_classifier:Utf8, __mr_match_number:UInt64, __mr_is_last_match_row:Boolean]
07)------------CoalesceBatchesExec: target_batch_size=8192, schema=[company:Utf8View;N, price_date:Date32;N, __mr_classifier:Utf8, __mr_match_number:UInt64, __mr_is_last_match_row:Boolean]
08)--------------RepartitionExec: partitioning=Hash([company@0, __mr_match_number@3], 4), input_partitions=4, schema=[company:Utf8View;N, price_date:Date32;N, __mr_classifier:Utf8, __mr_match_number:UInt64, __mr_is_last_match_row:Boolean]
09)----------------RepartitionExec: partitioning=RoundRobinBatch(4), input_partitions=1, schema=[company:Utf8View;N, price_date:Date32;N, __mr_classifier:Utf8, __mr_match_number:UInt64, __mr_is_last_match_row:Boolean]
10)------------------ProjectionExec: expr=[company@0 as company, price_date@1 as price_date, __mr_classifier@4 as __mr_classifier, __mr_match_number@5 as __mr_match_number, __mr_is_last_match_row@7 as __mr_is_last_match_row], schema=[company:Utf8View;N, price_date:Date32;N, __mr_classifier:Utf8, __mr_match_number:UInt64, __mr_is_last_match_row:Boolean]
11)--------------------MatchRecognizePatternExec: pattern=[A+], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A:Boolean;N, __mr_classifier:Utf8, __mr_match_number:UInt64, __mr_match_sequence_number:UInt64, __mr_is_last_match_row:Boolean, __mr_is_included_row:Boolean]
12)----------------------SortExec: expr=[company@0 ASC NULLS LAST, price_date@1 ASC NULLS LAST], preserve_partitioning=[false], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A:Boolean;N]
13)------------------------ProjectionExec: expr=[company@0 as company, price_date@1 as price_date, price@2 as price, price@2 > 100 as __mr_symbol_A], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A:Boolean;N]
14)--------------------------DataSourceExec: partitions=1, partition_sizes=[1], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N]

