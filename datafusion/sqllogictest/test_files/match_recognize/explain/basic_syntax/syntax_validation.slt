# Test complex expression parsing
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    MEASURES
        CASE WHEN price > 100 THEN 'HIGH' ELSE 'LOW' END AS price_category,
        price + 10 * 2 AS adjusted_price,
        COALESCE(price, 0) AS safe_price
    PATTERN (A)
    DEFINE A AS price > 50 AND (company = 'ACME' OR company = 'BETA')
)
----
logical_plan
01)Projection: CASE WHEN stock_price.price > Int32(100) THEN Utf8("HIGH") ELSE Utf8("LOW") END AS price_category, __common_expr_1 + Int64(20) AS adjusted_price, coalesce(__common_expr_1, Int64(0)) AS safe_price
02)--Projection: CAST(stock_price.price AS Int64) AS __common_expr_1, stock_price.price
03)----Filter: __mr_is_last_match_row
04)------Projection: stock_price.price, __mr_is_last_match_row
05)--------MatchRecognizePattern: pattern=[A]
06)----------Projection: stock_price.company, stock_price.price_date, stock_price.price, stock_price.price > Int32(50) AND (stock_price.company = Utf8View("ACME") OR stock_price.company = Utf8View("BETA")) AS __mr_symbol_A
07)------------TableScan: stock_price projection=[company, price_date, price]
physical_plan
01)ProjectionExec: expr=[CASE WHEN price@1 > 100 THEN HIGH ELSE LOW END as price_category, __common_expr_1@0 + 20 as adjusted_price, coalesce(__common_expr_1@0, 0) as safe_price], schema=[price_category:Utf8, adjusted_price:Int64;N, safe_price:Int64]
02)--ProjectionExec: expr=[CAST(price@0 AS Int64) as __common_expr_1, price@0 as price], schema=[__common_expr_1:Int64;N, price:Int32;N]
03)----CoalesceBatchesExec: target_batch_size=8192, schema=[price:Int32;N]
04)------FilterExec: __mr_is_last_match_row@1, projection=[price@0], schema=[price:Int32;N]
05)--------RepartitionExec: partitioning=RoundRobinBatch(4), input_partitions=1, schema=[price:Int32;N, __mr_is_last_match_row:Boolean]
06)----------ProjectionExec: expr=[price@2 as price, __mr_is_last_match_row@7 as __mr_is_last_match_row], schema=[price:Int32;N, __mr_is_last_match_row:Boolean]
07)------------MatchRecognizePatternExec: pattern=[A], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A:Boolean;N, __mr_classifier:Utf8, __mr_match_number:UInt64, __mr_match_sequence_number:UInt64, __mr_is_last_match_row:Boolean, __mr_is_included_row:Boolean]
08)--------------ProjectionExec: expr=[company@0 as company, price_date@1 as price_date, price@2 as price, price@2 > 50 AND (company@0 = ACME OR company@0 = BETA) as __mr_symbol_A], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A:Boolean;N]
