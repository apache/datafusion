# Test nested expressions
query error DataFusion error: Schema error: Schema contains duplicate unqualified field name "lag\(stock_price\.price,Int64\(1\),Int64\(0\)\) PARTITION BY \[stock_price\.company\] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING"
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    PARTITION BY company
    MEASURES
        ABS(price - LAG(price, 1, 0)) AS price_change
    PATTERN (A+)
    DEFINE
        A AS ABS(price - LAG(price, 1, 0)) > 10
)

