# Import common test data
include ../../init_data.slt.part

# Test invalid SQL syntax - missing opening parenthesis
query error DataFusion error: SQL error: ParserError\("Expected: \(, found: PATTERN at Line: 3, Column: 5"\)
SELECT * FROM stock_price
MATCH_RECOGNIZE
    PATTERN (A)
    DEFINE A AS price > 100
)

# Test invalid SQL syntax - missing closing parenthesis
query error DataFusion error: SQL error: ParserError\("Expected: \), found: EOF"\)
SELECT * FROM stock_price
MATCH_RECOGNIZE (
    PATTERN (A)
    DEFINE A AS price > 100

# Test invalid PATTERN syntax
query error DataFusion error: SQL error: ParserError\("Expected: \(, found: A at Line: 3, Column: 13"\)
SELECT * FROM stock_price
MATCH_RECOGNIZE (
    PATTERN A)
    DEFINE A AS price > 100
)

# Test invalid DEFINE syntax
query error DataFusion error: SQL error: ParserError\("Expected: AS, found: price at Line: 4, Column: 14"\)
SELECT * FROM stock_price
MATCH_RECOGNIZE (
    PATTERN (A)
    DEFINE A price > 100
)

# Test valid identifier names
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    PARTITION BY company
    ORDER BY price_date
    MEASURES
        price AS current_price_value,
        company AS stock_symbol
    PATTERN (A1 B2 C_3)
    DEFINE
        A1 AS price > 100,
        B2 AS company = 'ACME',
        C_3 AS price_date IS NOT NULL
)
----
logical_plan
01)Projection: stock_price.company, stock_price.price AS current_price_value, stock_price.company AS stock_symbol
02)--Filter: __mr_is_last_match_row
03)----Projection: stock_price.company, stock_price.price, __mr_is_last_match_row
04)------MatchRecognizePattern: partition_by=[stock_price.company] order_by=[stock_price.price_date ASC NULLS LAST] pattern=[A1 B2 C_3]
05)--------Projection: stock_price.company, stock_price.price_date, stock_price.price, stock_price.price > Int32(100) AS __mr_symbol_A1, stock_price.company = Utf8View("ACME") AS __mr_symbol_B2, stock_price.price_date IS NOT NULL AS __mr_symbol_C_3
06)----------TableScan: stock_price projection=[company, price_date, price]
physical_plan
01)ProjectionExec: expr=[company@0 as company, price@1 as current_price_value, company@0 as stock_symbol], schema=[company:Utf8View;N, current_price_value:Int32;N, stock_symbol:Utf8View;N]
02)--CoalesceBatchesExec: target_batch_size=8192, schema=[company:Utf8View;N, price:Int32;N]
03)----FilterExec: __mr_is_last_match_row@2, projection=[company@0, price@1], schema=[company:Utf8View;N, price:Int32;N]
04)------RepartitionExec: partitioning=RoundRobinBatch(4), input_partitions=1, schema=[company:Utf8View;N, price:Int32;N, __mr_is_last_match_row:Boolean]
05)--------ProjectionExec: expr=[company@0 as company, price@2 as price, __mr_is_last_match_row@9 as __mr_is_last_match_row], schema=[company:Utf8View;N, price:Int32;N, __mr_is_last_match_row:Boolean]
06)----------MatchRecognizePatternExec: pattern=[A1 B2 C_3], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A1:Boolean;N, __mr_symbol_B2:Boolean;N, __mr_symbol_C_3:Boolean, __mr_classifier:Utf8, __mr_match_number:UInt64, __mr_match_sequence_number:UInt64, __mr_is_last_match_row:Boolean, __mr_is_included_row:Boolean]
07)------------SortExec: expr=[company@0 ASC NULLS LAST, price_date@1 ASC NULLS LAST], preserve_partitioning=[false], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A1:Boolean;N, __mr_symbol_B2:Boolean;N, __mr_symbol_C_3:Boolean]
08)--------------ProjectionExec: expr=[company@0 as company, price_date@1 as price_date, price@2 as price, price@2 > 100 as __mr_symbol_A1, company@0 = ACME as __mr_symbol_B2, price_date@1 IS NOT NULL as __mr_symbol_C_3], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A1:Boolean;N, __mr_symbol_B2:Boolean;N, __mr_symbol_C_3:Boolean]
09)----------------DataSourceExec: partitions=1, partition_sizes=[1], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N]

# Test case sensitivity
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    MEASURES price AS current_price
    ONE ROW PER MATCH
    PATTERN (UpTrend DownTrend)
    DEFINE
        UpTrend AS price > 100,
        DownTrend AS price < 50
)
----
logical_plan
01)Projection: stock_price.price AS current_price
02)--Filter: __mr_is_last_match_row
03)----Projection: stock_price.price, __mr_is_last_match_row
04)------MatchRecognizePattern: pattern=[UpTrend DownTrend]
05)--------Projection: stock_price.company, stock_price.price_date, stock_price.price, stock_price.price < Int32(50) AS __mr_symbol_DownTrend, stock_price.price > Int32(100) AS __mr_symbol_UpTrend
06)----------TableScan: stock_price projection=[company, price_date, price]
physical_plan
01)ProjectionExec: expr=[price@0 as current_price], schema=[current_price:Int32;N]
02)--CoalesceBatchesExec: target_batch_size=8192, schema=[price:Int32;N]
03)----FilterExec: __mr_is_last_match_row@1, projection=[price@0], schema=[price:Int32;N]
04)------RepartitionExec: partitioning=RoundRobinBatch(4), input_partitions=1, schema=[price:Int32;N, __mr_is_last_match_row:Boolean]
05)--------ProjectionExec: expr=[price@2 as price, __mr_is_last_match_row@8 as __mr_is_last_match_row], schema=[price:Int32;N, __mr_is_last_match_row:Boolean]
06)----------MatchRecognizePatternExec: pattern=[UpTrend DownTrend], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_DownTrend:Boolean;N, __mr_symbol_UpTrend:Boolean;N, __mr_classifier:Utf8, __mr_match_number:UInt64, __mr_match_sequence_number:UInt64, __mr_is_last_match_row:Boolean, __mr_is_included_row:Boolean]
07)------------ProjectionExec: expr=[company@0 as company, price_date@1 as price_date, price@2 as price, price@2 < 50 as __mr_symbol_DownTrend, price@2 > 100 as __mr_symbol_UpTrend], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_DownTrend:Boolean;N, __mr_symbol_UpTrend:Boolean;N]
08)--------------DataSourceExec: partitions=1, partition_sizes=[1], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N]

