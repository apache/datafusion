# Import common test data
include ../../init_data.slt.part

# Test ORDER BY single column
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    PARTITION BY company
    ORDER BY price_date
    MEASURES price AS p
    PATTERN (A)
    DEFINE A AS price > 100
)
----
logical_plan
01)Projection: stock_price.company, stock_price.price AS p
02)--Filter: __mr_is_last_match_row
03)----Projection: stock_price.company, stock_price.price, __mr_is_last_match_row
04)------MatchRecognizePattern: partition_by=[stock_price.company] order_by=[stock_price.price_date ASC NULLS LAST] pattern=[A]
05)--------Projection: stock_price.company, stock_price.price_date, stock_price.price, stock_price.price > Int32(100) AS __mr_symbol_A
06)----------TableScan: stock_price projection=[company, price_date, price]
physical_plan
01)ProjectionExec: expr=[company@0 as company, price@1 as p], schema=[company:Utf8View;N, p:Int32;N]
02)--CoalesceBatchesExec: target_batch_size=8192, schema=[company:Utf8View;N, price:Int32;N]
03)----FilterExec: __mr_is_last_match_row@2, projection=[company@0, price@1], schema=[company:Utf8View;N, price:Int32;N]
04)------RepartitionExec: partitioning=RoundRobinBatch(4), input_partitions=1, schema=[company:Utf8View;N, price:Int32;N, __mr_is_last_match_row:Boolean]
05)--------ProjectionExec: expr=[company@0 as company, price@2 as price, __mr_is_last_match_row@7 as __mr_is_last_match_row], schema=[company:Utf8View;N, price:Int32;N, __mr_is_last_match_row:Boolean]
06)----------MatchRecognizePatternExec: pattern=Symbol(Named("A")), schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A:Boolean;N, __mr_classifier:Utf8, __mr_match_number:UInt64, __mr_match_sequence_number:UInt64, __mr_is_last_match_row:Boolean, __mr_is_included_row:Boolean]
07)------------SortExec: expr=[company@0 ASC NULLS LAST, price_date@1 ASC NULLS LAST], preserve_partitioning=[false], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A:Boolean;N]
08)--------------ProjectionExec: expr=[company@0 as company, price_date@1 as price_date, price@2 as price, price@2 > 100 as __mr_symbol_A], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A:Boolean;N]
09)----------------DataSourceExec: partitions=1, partition_sizes=[1], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N]

# Test ORDER BY directions
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    ORDER BY price_date ASC, price DESC
    MEASURES price AS p
    PATTERN (A)
    DEFINE A AS price > 100
)
----
logical_plan
01)Projection: stock_price.price AS p
02)--Filter: __mr_is_last_match_row
03)----Projection: stock_price.price, __mr_is_last_match_row
04)------MatchRecognizePattern: order_by=[stock_price.price_date ASC NULLS LAST, stock_price.price DESC NULLS FIRST] pattern=[A]
05)--------Projection: stock_price.company, stock_price.price_date, stock_price.price, stock_price.price > Int32(100) AS __mr_symbol_A
06)----------TableScan: stock_price projection=[company, price_date, price]
physical_plan
01)ProjectionExec: expr=[price@0 as p], schema=[p:Int32;N]
02)--CoalesceBatchesExec: target_batch_size=8192, schema=[price:Int32;N]
03)----FilterExec: __mr_is_last_match_row@1, projection=[price@0], schema=[price:Int32;N]
04)------RepartitionExec: partitioning=RoundRobinBatch(4), input_partitions=1, schema=[price:Int32;N, __mr_is_last_match_row:Boolean]
05)--------ProjectionExec: expr=[price@2 as price, __mr_is_last_match_row@7 as __mr_is_last_match_row], schema=[price:Int32;N, __mr_is_last_match_row:Boolean]
06)----------MatchRecognizePatternExec: pattern=Symbol(Named("A")), schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A:Boolean;N, __mr_classifier:Utf8, __mr_match_number:UInt64, __mr_match_sequence_number:UInt64, __mr_is_last_match_row:Boolean, __mr_is_included_row:Boolean]
07)------------SortExec: expr=[price_date@1 ASC NULLS LAST, price@2 DESC], preserve_partitioning=[false], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A:Boolean;N]
08)--------------ProjectionExec: expr=[company@0 as company, price_date@1 as price_date, price@2 as price, price@2 > 100 as __mr_symbol_A], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A:Boolean;N]
09)----------------DataSourceExec: partitions=1, partition_sizes=[1], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N]

# Test NULLS handling
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    ORDER BY price NULLS FIRST, price_date NULLS LAST
    MEASURES price AS p
    PATTERN (A)
    DEFINE A AS price > 100
)
----
logical_plan
01)Projection: stock_price.price AS p
02)--Filter: __mr_is_last_match_row
03)----Projection: stock_price.price, __mr_is_last_match_row
04)------MatchRecognizePattern: order_by=[stock_price.price ASC NULLS FIRST, stock_price.price_date ASC NULLS LAST] pattern=[A]
05)--------Projection: stock_price.company, stock_price.price_date, stock_price.price, stock_price.price > Int32(100) AS __mr_symbol_A
06)----------TableScan: stock_price projection=[company, price_date, price]
physical_plan
01)ProjectionExec: expr=[price@0 as p], schema=[p:Int32;N]
02)--CoalesceBatchesExec: target_batch_size=8192, schema=[price:Int32;N]
03)----FilterExec: __mr_is_last_match_row@1, projection=[price@0], schema=[price:Int32;N]
04)------RepartitionExec: partitioning=RoundRobinBatch(4), input_partitions=1, schema=[price:Int32;N, __mr_is_last_match_row:Boolean]
05)--------ProjectionExec: expr=[price@2 as price, __mr_is_last_match_row@7 as __mr_is_last_match_row], schema=[price:Int32;N, __mr_is_last_match_row:Boolean]
06)----------MatchRecognizePatternExec: pattern=Symbol(Named("A")), schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A:Boolean;N, __mr_classifier:Utf8, __mr_match_number:UInt64, __mr_match_sequence_number:UInt64, __mr_is_last_match_row:Boolean, __mr_is_included_row:Boolean]
07)------------SortExec: expr=[price@2 ASC, price_date@1 ASC NULLS LAST], preserve_partitioning=[false], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A:Boolean;N]
08)--------------ProjectionExec: expr=[company@0 as company, price_date@1 as price_date, price@2 as price, price@2 > 100 as __mr_symbol_A], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A:Boolean;N]
09)----------------DataSourceExec: partitions=1, partition_sizes=[1], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N]

# Test ORDER BY expressions
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    ORDER BY price * 2
    MEASURES price AS p
    PATTERN (A)
    DEFINE A AS price > 100
)
----
logical_plan
01)Projection: stock_price.price AS p
02)--Filter: __mr_is_last_match_row
03)----Projection: stock_price.price, __mr_is_last_match_row
04)------MatchRecognizePattern: order_by=[CAST(stock_price.price AS Int64) * Int64(2) ASC NULLS LAST] pattern=[A]
05)--------Projection: stock_price.company, stock_price.price_date, stock_price.price, stock_price.price > Int32(100) AS __mr_symbol_A
06)----------TableScan: stock_price projection=[company, price_date, price]
physical_plan
01)ProjectionExec: expr=[price@0 as p], schema=[p:Int32;N]
02)--CoalesceBatchesExec: target_batch_size=8192, schema=[price:Int32;N]
03)----FilterExec: __mr_is_last_match_row@1, projection=[price@0], schema=[price:Int32;N]
04)------RepartitionExec: partitioning=RoundRobinBatch(4), input_partitions=1, schema=[price:Int32;N, __mr_is_last_match_row:Boolean]
05)--------ProjectionExec: expr=[price@2 as price, __mr_is_last_match_row@7 as __mr_is_last_match_row], schema=[price:Int32;N, __mr_is_last_match_row:Boolean]
06)----------MatchRecognizePatternExec: pattern=Symbol(Named("A")), schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A:Boolean;N, __mr_classifier:Utf8, __mr_match_number:UInt64, __mr_match_sequence_number:UInt64, __mr_is_last_match_row:Boolean, __mr_is_included_row:Boolean]
07)------------SortExec: expr=[CAST(price@2 AS Int64) * 2 ASC NULLS LAST], preserve_partitioning=[false], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A:Boolean;N]
08)--------------ProjectionExec: expr=[company@0 as company, price_date@1 as price_date, price@2 as price, price@2 > 100 as __mr_symbol_A], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A:Boolean;N]
09)----------------DataSourceExec: partitions=1, partition_sizes=[1], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N]

# Test ORDER BY invalid column
query error DataFusion error: Schema error: No field named nonexistent_column\. Valid fields are stock_price\.company, stock_price\.price_date, stock_price\.price, "__mr_symbol_A"\.
SELECT * FROM stock_price
MATCH_RECOGNIZE (
    ORDER BY nonexistent_column
    MEASURES price AS p
    PATTERN (A)
    DEFINE A AS price > 100
)

# Test no ORDER BY clause
