# Test output schema ALL ROWS PER MATCH
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    ORDER BY price_date
    MEASURES
        LAG(price) AS prev_price
    ALL ROWS PER MATCH
    PATTERN (A)
    DEFINE A AS price > 100
)
