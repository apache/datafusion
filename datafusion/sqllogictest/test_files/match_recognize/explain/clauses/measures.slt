# Test MEASURES with multiple window functions
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    ORDER BY price_date
    MEASURES
        LAG(price) AS prev_price,
        LEAD(price) AS next_price,
        FIRST_VALUE(price) AS first_price
    ONE ROW PER MATCH
    PATTERN (A B)
    DEFINE
        A AS price > 100,
        B AS price < 50
)
----
