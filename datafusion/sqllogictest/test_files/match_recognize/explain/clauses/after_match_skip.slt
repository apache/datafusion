# Test AFTER MATCH SKIP TO symbol shorthand (should fail)
query error DataFusion error: SQL error: ParserError\("Expected: after match skip option, found: TO at Line: 5, Column: 22"\)
SELECT * FROM stock_price
MATCH_RECOGNIZE (
    ORDER BY price_date
    MEASURES price AS current_price
    AFTER MATCH SKIP TO A
    PATTERN (A B)
    DEFINE
        A AS price > 100,
        B AS price < 50
)

# Test skip to undefined symbol (parses successfully)
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    ORDER BY price_date
    MEASURES price AS current_price
    AFTER MATCH SKIP TO FIRST C
    PATTERN (A B)
    DEFINE
        A AS price > 100,
        B AS price < 50
)
