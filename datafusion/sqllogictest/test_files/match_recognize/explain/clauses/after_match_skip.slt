# Test AFTER MATCH SKIP with complex pattern
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    ORDER BY price_date
    MEASURES price AS current_price
    AFTER MATCH SKIP TO LAST RISE
    PATTERN (FALL+ RISE+)
    DEFINE
        FALL AS price < LAG(price),
        RISE AS price > LAG(price)
)
