04)------ProjectionExec: expr=[company@0 as company, __mr_is_last_match_row@5 as __mr_is_last_match_row, first(stock_price.price,__mr_classifier,NULL) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING@6 as first(stock_price.price,__mr_classifier,NULL) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING, last(stock_price.price,__mr_classifier,NULL) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING@7 as last(stock_price.price,__mr_classifier,NULL) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING], schema=[company:Utf8View;N, __mr_is_last_match_row:Boolean, first(stock_price.price,__mr_classifier,NULL) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING:Int32;N, last(stock_price.price,__mr_classifier,NULL) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING:Int32;N]
