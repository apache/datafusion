# Test schema building for ALL ROWS PER MATCH - should include ALL input columns + MEASURES
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE(
    PARTITION BY company
    ORDER BY price_date
    MEASURES
        FIRST(price) AS start_price,
        LAST(price) AS end_price
    ALL ROWS PER MATCH
    PATTERN (A B)
    DEFINE
        A AS price > 100,
        B AS price < 50
)
