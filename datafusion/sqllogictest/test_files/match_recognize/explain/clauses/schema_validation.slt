# Test schema building for ONE ROW PER MATCH with only PARTITION BY (no MEASURES)
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE(
    PARTITION BY company
    ORDER BY price_date
    ONE ROW PER MATCH
    PATTERN (A B)
    DEFINE
        A AS price > 100,
        B AS price < 50
)
----
logical_plan
01)Projection: stock_price.company
