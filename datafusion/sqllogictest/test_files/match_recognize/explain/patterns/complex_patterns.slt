# tests for EXPLAIN with display schema enabled
statement ok
set datafusion.explain.show_schema = true;

# Test setup - create test table
statement ok
CREATE TABLE stock_price (
    company VARCHAR,
    price_date DATE,
    price INTEGER
);

# Test basic complex pattern
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    MEASURES price as p
    PATTERN (A B)
    DEFINE A AS price > 100
)
----
logical_plan
01)Projection: stock_price.price AS p
02)--Filter: __mr_is_last_match_row
03)----Projection: stock_price.price, __mr_is_last_match_row
04)------MatchRecognizePattern: pattern=[A B]
05)--------Projection: stock_price.company, stock_price.price_date, stock_price.price, stock_price.price > Int32(100) AS __mr_symbol_A, Boolean(true) AS __mr_symbol_B
06)----------TableScan: stock_price projection=[company, price_date, price]
physical_plan
01)ProjectionExec: expr=[price@0 as p], schema=[p:Int32;N]
02)--CoalesceBatchesExec: target_batch_size=8192, schema=[price:Int32;N]
03)----FilterExec: __mr_is_last_match_row@1, projection=[price@0], schema=[price:Int32;N]
04)------RepartitionExec: partitioning=RoundRobinBatch(4), input_partitions=1, schema=[price:Int32;N, __mr_is_last_match_row:Boolean]
05)--------ProjectionExec: expr=[price@2 as price, __mr_is_last_match_row@8 as __mr_is_last_match_row], schema=[price:Int32;N, __mr_is_last_match_row:Boolean]
06)----------MatchRecognizePatternExec: pattern=[A B], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A:Boolean;N, __mr_symbol_B:Boolean, __mr_classifier:Utf8, __mr_match_number:UInt64, __mr_match_sequence_number:UInt64, __mr_is_last_match_row:Boolean, __mr_is_included_row:Boolean]
07)------------ProjectionExec: expr=[company@0 as company, price_date@1 as price_date, price@2 as price, price@2 > 100 as __mr_symbol_A, true as __mr_symbol_B], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N, __mr_symbol_A:Boolean;N, __mr_symbol_B:Boolean]
08)--------------DataSourceExec: partitions=1, partition_sizes=[0], schema=[company:Utf8View;N, price_date:Date32;N, price:Int32;N]
