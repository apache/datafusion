# Test quantifier on start end symbols
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    MEASURES price AS current_price
    ONE ROW PER MATCH
    PATTERN (^+ A $*)
    DEFINE A AS price > 100
)
