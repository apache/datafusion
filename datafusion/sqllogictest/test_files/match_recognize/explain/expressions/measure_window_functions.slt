# Test multiple window functions
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    ORDER BY price_date
    MEASURES
        LAG(price) AS prev_price,
        LEAD(price) AS next_price,
        FIRST_VALUE(price) AS first_price,
        LAST_VALUE(price) AS last_price
    ONE ROW PER MATCH
    PATTERN (A+)
    DEFINE A AS price > 50
)
----
