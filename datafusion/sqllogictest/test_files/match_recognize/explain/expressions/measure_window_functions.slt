# Test window function with offset
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    ORDER BY price_date
    MEASURES price AS p
    PATTERN (A)
    DEFINE A AS price > LAG(price, 2)
)
----
logical_plan
01)Projection: stock_price.price AS p
02)--Filter: __mr_is_last_match_row
03)----Projection: stock_price.price, __mr_is_last_match_row
04)------MatchRecognizePattern: order_by=[stock_price.price_date ASC NULLS LAST] pattern=[A]
05)--------Projection: stock_price.company, stock_price.price_date, stock_price.price, lag(stock_price.price,Int64(2)) ORDER BY [stock_price.price_date ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING, stock_price.price > lag(stock_price.price,Int64(2)) ORDER BY [stock_price.price_date ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING AS __mr_symbol_A
06)----------WindowAggr: windowExpr=[[lag(stock_price.price, Int64(2)) ORDER BY [stock_price.price_date ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING]]
