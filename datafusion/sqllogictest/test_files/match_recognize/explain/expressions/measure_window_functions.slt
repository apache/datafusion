# Test rank window functions
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    ORDER BY price_date
    MEASURES
        ROW_NUMBER() AS row_num,
        RANK() AS rank_val,
        DENSE_RANK() AS dense_rank_val
    ONE ROW PER MATCH
    PATTERN (A+)
    DEFINE A AS price > 50
)
