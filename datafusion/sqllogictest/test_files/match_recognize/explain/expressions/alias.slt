# Test selecting with an expression on an aliased measure
query TT
EXPLAIN SELECT current_price * 1.1 AS adjusted_price
FROM stock_price
MATCH_RECOGNIZE (
    ORDER BY price_date
    MEASURES
        price AS current_price
    ONE ROW PER MATCH
    PATTERN (A)
    DEFINE A AS price > 100
)
