# Test selecting both partition key and aliased measures
query TT
EXPLAIN SELECT company, prev_price
FROM stock_price
MATCH_RECOGNIZE (
    PARTITION BY company
    ORDER BY price_date
    MEASURES
        price AS current_price,
        LAG(price) AS prev_price
    ONE ROW PER MATCH
    PATTERN (A)
    DEFINE A AS price > 100
)
----
