# Test selecting aliased measures
query TT
EXPLAIN SELECT current_price, match_count
FROM stock_price
MATCH_RECOGNIZE (
    ORDER BY price_date
    MEASURES
        price AS current_price,
        LAG(price) AS prev_price,
        COUNT(*) AS match_count
    ONE ROW PER MATCH
    PATTERN (A)
    DEFINE A AS price > 100
)
----
logical_plan
01)Projection: stock_price.price AS current_price, count(CASE WHEN __mr_classifier != Utf8("(empty)") THEN Int64(1) ELSE NULL END) PARTITION BY [__mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING AS match_count
