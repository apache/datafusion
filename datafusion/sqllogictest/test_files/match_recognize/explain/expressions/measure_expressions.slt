# Test measure complex expressions
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    ORDER BY price_date
    MEASURES
        CASE WHEN price > 100 THEN 'high' ELSE 'low' END AS price_category,
        price * (1 + 0.1) AS price_with_tax
    ONE ROW PER MATCH
    PATTERN (A)
    DEFINE A AS price > 50
)
