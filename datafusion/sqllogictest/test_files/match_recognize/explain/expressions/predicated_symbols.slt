# Test predicated symbols in complex expressions in MEASURES
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    PARTITION BY company
    ORDER BY price_date
    MEASURES
        CASE WHEN A.price < 30 THEN 'low' ELSE 'mid' END AS a_category,
        B.price * 2 AS b_double
    ONE ROW PER MATCH
    PATTERN (A+ B+)
    DEFINE
        A AS price < 50,
        B AS price > 60
)
----
logical_plan
01)Projection: stock_price.company, CASE WHEN last(a.price,__mr_classifier,Utf8("a")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING < Int32(30) THEN Utf8("low") ELSE Utf8("mid") END AS a_category, CAST(last(b.price,__mr_classifier,Utf8("b")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING AS Int64) * Int64(2) AS b_double
02)--Filter: __mr_is_last_match_row
03)----Projection: stock_price.company, __mr_is_last_match_row, last(a.price,__mr_classifier,Utf8("a")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING, last(b.price,__mr_classifier,Utf8("b")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING
04)------WindowAggr: windowExpr=[[last(a.price, __mr_classifier, Utf8("a")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING, last(b.price, __mr_classifier, Utf8("b")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING]]
05)--------Projection: stock_price.company, stock_price.price, __mr_classifier, __mr_is_last_match_row
