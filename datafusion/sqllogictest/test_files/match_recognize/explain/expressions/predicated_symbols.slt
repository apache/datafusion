# Test predicated symbols in MEASURES clause with window functions
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    PARTITION BY company
    ORDER BY price_date
    MEASURES
        LAG(A.price) AS lag_a_price,
        LEAD(B.price) AS lead_b_price,
        FIRST_VALUE(A.price) AS fv_a_price,
        LAST_VALUE(B.price) AS lv_b_price
    ONE ROW PER MATCH
    PATTERN (A+ B+)
    DEFINE
        A AS price < 50,
        B AS price > 60
)
----
logical_plan
01)Projection: stock_price.company, prev(a.price,__mr_classifier,Utf8("a"),NULL,NULL) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING AS lag_a_price, next(b.price,__mr_classifier,Utf8("b"),NULL,NULL) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING AS lead_b_price, first(a.price,__mr_classifier,Utf8("a")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING AS fv_a_price, last(b.price,__mr_classifier,Utf8("b")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING AS lv_b_price
02)--Filter: __mr_is_last_match_row
03)----Projection: stock_price.company, __mr_is_last_match_row, prev(a.price,__mr_classifier,Utf8("a"),NULL,NULL) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING, next(b.price,__mr_classifier,Utf8("b"),NULL,NULL) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING, first(a.price,__mr_classifier,Utf8("a")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING, last(b.price,__mr_classifier,Utf8("b")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING
04)------WindowAggr: windowExpr=[[prev(a.price, __mr_classifier, Utf8("a"), NULL, NULL) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING, next(b.price, __mr_classifier, Utf8("b"), NULL, NULL) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING, first(a.price, __mr_classifier, Utf8("a")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING, last(b.price, __mr_classifier, Utf8("b")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING]]
05)--------Projection: stock_price.company, stock_price.price, __mr_classifier, __mr_is_last_match_row
06)----------MatchRecognizePattern: partition_by=[stock_price.company] order_by=[stock_price.price_date ASC NULLS LAST] pattern=[A+ B+]
07)------------Projection: stock_price.company, stock_price.price_date, stock_price.price, stock_price.price < Int32(50) AS __mr_symbol_A, stock_price.price > Int32(60) AS __mr_symbol_B
