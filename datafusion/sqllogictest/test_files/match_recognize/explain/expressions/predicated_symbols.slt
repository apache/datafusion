# Test predicated symbols in aggregates in MEASURES clause with ALL ROWS PER MATCH
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    PARTITION BY company
    ORDER BY price_date
    MEASURES
        COUNT(A.*) AS a_count,
        COUNT(B.*) AS b_count
    ALL ROWS PER MATCH
    PATTERN (A+ B+)
    DEFINE
        A AS price < 50,
        B AS price > 60
)
