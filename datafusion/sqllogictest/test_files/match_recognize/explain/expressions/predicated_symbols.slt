# Import common test data
include ../../init_data.slt.part

# Test predicated symbols in MEASURES clause
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    PARTITION BY company
    ORDER BY price_date
    MEASURES
        A.price AS a_price,
        B.price AS b_price,
        FIRST(A.price) AS first_a_price,
        LAST(B.price) AS last_b_price
    ONE ROW PER MATCH
    PATTERN (A+ B+)
    DEFINE
        A AS price < 50,
        B AS price > 60
)
----
logical_plan
01)Projection: stock_price.company, last(a.price,__mr_classifier,Utf8("a")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING AS a_price, last(b.price,__mr_classifier,Utf8("b")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING AS b_price, first(a.price,__mr_classifier,Utf8("a")) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING AS first_a_price, last(b.price,__mr_classifier,Utf8("b")) PARTITION BY [stock_price.company, __mr_match_number] ORDER BY [stock_price.price_date ASC NULLS LAST, __mr_match_number ASC NULLS LAST] ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING AS last_b_price
