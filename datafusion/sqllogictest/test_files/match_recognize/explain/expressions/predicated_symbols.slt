# Test predicated symbols in MEASURES with symbol predicates on non-adjacent symbols
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    PARTITION BY company
    ORDER BY price_date
    MEASURES
        A.price AS a_price,
        C.price AS c_price
    ONE ROW PER MATCH
    PATTERN (A+ B+ C+)
    DEFINE
        A AS price < 40,
        B AS price BETWEEN 40 AND 60,
        C AS price > 60
)
----
logical_plan
01)Projection: stock_price.company, last(a.price,__mr_classifier,Utf8("a")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING AS a_price, last(c.price,__mr_classifier,Utf8("c")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING AS c_price
02)--Filter: __mr_is_last_match_row
03)----Projection: stock_price.company, __mr_is_last_match_row, last(a.price,__mr_classifier,Utf8("a")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING, last(c.price,__mr_classifier,Utf8("c")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING
04)------WindowAggr: windowExpr=[[last(a.price, __mr_classifier, Utf8("a")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING, last(c.price, __mr_classifier, Utf8("c")) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING]]
05)--------Projection: stock_price.company, stock_price.price, __mr_classifier, __mr_is_last_match_row
06)----------MatchRecognizePattern: partition_by=[stock_price.company] order_by=[stock_price.price_date ASC NULLS LAST] pattern=[A+ B+ C+]
07)------------Projection: stock_price.company, stock_price.price_date, stock_price.price, stock_price.price < Int32(40) AS __mr_symbol_A, stock_price.price >= Int32(40) AND stock_price.price <= Int32(60) AS __mr_symbol_B, stock_price.price > Int32(60) AS __mr_symbol_C
