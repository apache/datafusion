# Test multiple window functions
query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    ALL ROWS PER MATCH
    PATTERN (A B C D)
    DEFINE A AS LAG(price) < price,
           B AS LEAD(price) > price,
           C AS FIRST_VALUE(price) < price,
           D AS LAST_VALUE(price) > price
)
----
logical_plan
01)Projection: stock_price.company, stock_price.price_date, stock_price.price
02)--Filter: __mr_is_included_row
03)----Projection: stock_price.company, stock_price.price_date, stock_price.price, __mr_is_included_row
04)------MatchRecognizePattern: pattern=[A B C D]
