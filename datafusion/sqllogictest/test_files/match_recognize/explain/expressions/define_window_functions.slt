# Test aggregate window functions
query error DataFusion error: Schema error: No field named __mr_classifier\. Valid fields are stock_price\.company, stock_price\.price_date, stock_price\.price\.
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    ALL ROWS PER MATCH
    PATTERN (A+)
    DEFINE A AS price > SUM(price) OVER (ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW)
)
