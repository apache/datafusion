query TT
EXPLAIN SELECT * FROM stock_price
MATCH_RECOGNIZE (
    ORDER BY price_date
    MEASURES
        FIRST(company) AS first_company,
        LAST(price_date) AS last_date,
        PREV(price) AS prev_price,
        CLASSIFIER() AS symbol
    ONE ROW PER MATCH
    PATTERN (A+)
    DEFINE A AS price > 50
)
