# array_concat column-wise #7
query ?
select array_concat(column3, make_array('.', '.', '.')) from arrays;
----
[L, o, r, e, m, ., ., .]
[i, p, NULL, u, m, ., ., .]
[d, NULL, l, o, r, ., ., .]
[s, i, t, ., ., .]
[a, m, e, t, ., ., .]
