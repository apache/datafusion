# tests the variant_contains udf

query BB
SELECT variant_contains(json_to_variant('{"a": 1, "b": null}'), 'a'),
       variant_contains(json_to_variant('{"a": 1, "b": null}'), 'b');
----
true true

query B
SELECT variant_contains(json_to_variant('{"a": 1}'), 'b');
----
false

query B
SELECT variant_contains(json_to_variant('{"a": {"b": 1}}'), 'a.b');
----
true

query B
SELECT variant_contains(json_to_variant('{"a": {"b": 1}}'), 'a.c');
----
false

query B
SELECT variant_contains(json_to_variant('[10, 20, 30]'), '[1]');
----
true

query B
SELECT variant_contains(json_to_variant('[10, 20, 30]'), '[3]');
----
false

statement error DataFusion error: Execution error: path argument must be non-null
SELECT variant_contains(json_to_variant('{"a": 1}'), CAST(NULL AS TEXT));

statement ok
create table contains_paths(json_data text, path text) as values
  ('{"a": 1}', 'a'),
  ('{"a": 1}', null);

statement error DataFusion error: Execution error: path argument must be non-null
select variant_contains(json_to_variant(json_data), path)
from contains_paths;

statement ok
create table contains_data(json_data text) as values
  ('{"a": 1}'),
  ('{"b": 2}'),
  (null);

query BBB
select json_data is null,
       variant_contains(json_to_variant(json_data), 'a') is null,
       variant_contains(json_to_variant(json_data), 'a')
from contains_data;
----
false false true
false false false
true true NULL