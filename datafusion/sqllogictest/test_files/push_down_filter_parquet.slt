# LEFT SEMI JOIN: only matching build rows are returned; probe scan still
# receives the dynamic filter.
query TT
EXPLAIN ANALYZE
SELECT lj_build.*
FROM lj_build
WHERE EXISTS (
  SELECT 1 FROM lj_probe
  WHERE lj_probe.a = lj_build.a AND lj_probe.b = lj_build.b
);
