# constant aggregate expressions
query II
SELECT SUM(2+1), SUM(3) FROM sum_simplify_t;
----
12 12

query TT
EXPLAIN SELECT SUM(2+1), SUM(3) FROM sum_simplify_t;
----
logical_plan
