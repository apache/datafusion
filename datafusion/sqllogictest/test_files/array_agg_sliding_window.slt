statement ok
DROP TABLE t_dist_nulls;

statement ok
DROP TABLE t_dist_groups;

statement ok
DROP TABLE t_dist_growth;

statement ok
DROP TABLE t_dist_parts;

statement ok
DROP TABLE t_dist_int;