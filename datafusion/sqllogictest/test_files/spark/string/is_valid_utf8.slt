query B
SELECT is_valid_utf8('Spark'::string);
----
true

query B
SELECT is_valid_utf8(NULL::string);
----
NULL

query B
SELECT is_valid_utf8(arrow_cast(x'61', 'Binary'));
----
true

query B
SELECT is_valid_utf8(arrow_cast(x'80', 'Binary'));
----
false

query B
SELECT is_valid_utf8(arrow_cast(x'61C262', 'Binary'));
----
false
