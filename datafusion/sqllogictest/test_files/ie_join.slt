statement ok
SET datafusion.optimizer.enable_ie_join = true;

statement ok
CREATE TABLE ie_left (k TEXT, id INT, lo INT, hi INT);

statement ok
CREATE TABLE ie_right (k TEXT, id INT, lo INT, hi INT);

statement ok
INSERT INTO ie_left VALUES
  ('A', 1, 1, 3),
  ('A', 2, 5, 7),
  ('A', 3, 2, 6),
  ('B', 4, 2, 4),
  ('B', 5, NULL, 4),
  (NULL, 6, 1, 10);

statement ok
INSERT INTO ie_right VALUES
  ('A', 10, 1, 5),
  ('A', 11, 3, 5),
  ('A', 12, 8, 9),
  ('B', 13, 0, 2),
  ('B', 14, 5, 6),
  ('B', 15, NULL, 8),
  (NULL, 16, 0, 11);

# Keyed interval overlap with an additional cross-input residual predicate.
query II
SELECT l.id, r.id
FROM ie_left l
JOIN ie_right r
  ON l.k = r.k
 AND l.lo <= r.hi
 AND r.lo <= l.hi
 AND l.id + r.id < 14
ORDER BY 1, 2;
----
1 10
1 11
2 10
2 11
3 10

# Strict boundaries must not match intervals that only touch.
query II
SELECT l.id, r.id
FROM ie_left l
JOIN ie_right r
  ON l.k = r.k
 AND l.lo < r.hi
 AND r.lo < l.hi
ORDER BY 1, 2;
----
1 10
3 10
3 11

# IEJoin also works without equality keys.
query IIII
WITH
  l(id, lo, hi) AS (VALUES (1, 1, 4), (2, 5, 8)),
  r(id, lo, hi) AS (VALUES (10, 2, 3), (11, 4, 5), (12, 7, 9))
SELECT l.id, l.lo, r.id, r.hi
FROM l JOIN r
  ON l.lo <= r.hi
 AND r.lo <= l.hi
ORDER BY 1, 3;
----
1 1 10 3
1 1 11 5
2 5 11 5
2 5 12 9

statement ok
RESET datafusion.optimizer.enable_ie_join;
