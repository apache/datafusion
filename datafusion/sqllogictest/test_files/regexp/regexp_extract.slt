# Import common test data
include ./init_data.slt.part

# -----------------------------------------------------------------------
# Examples from pyspark documentation.
# https://spark.apache.org/docs/latest/api/python/reference/pyspark.sql/api/pyspark.sql.functions.regexp_extract.html

query T
SELECT regexp_extract('100-200', '(\d+)-(\d+)', 1);
----
100

query T
SELECT regexp_extract('100-200', '(\d+)-(\d+)', 2);
----
200

# -----------------------------------------------------------------------
# Common test data using implicit capture group.

query T
SELECT regexp_extract(str, pattern, 0) FROM regexp_test_data;
----
NULL
a
ABC
(empty)
(empty)
(empty)
(empty)
4010
Düsseldorf
Москва
Köln
إسرائيل

# -----------------------------------------------------------------------
# Test string view.

statement ok
CREATE TABLE t_stringview AS
SELECT arrow_cast(str, 'Utf8View') as str, arrow_cast(pattern, 'Utf8View') as pattern, arrow_cast(flags, 'Utf8View') as flags FROM regexp_test_data;

query T
SELECT regexp_extract(str, pattern, 0) FROM t_stringview;
----
NULL
a
ABC
(empty)
(empty)
(empty)
(empty)
4010
Düsseldorf
Москва
Köln
إسرائيل

statement ok
DROP TABLE t_stringview;

# -----------------------------------------------------------------------
# Test large utf8.

statement ok
CREATE TABLE t_largeutf8 AS
SELECT arrow_cast(str, 'LargeUtf8') as str, arrow_cast(pattern, 'LargeUtf8') as pattern, arrow_cast(flags, 'LargeUtf8') as flags FROM regexp_test_data;

query T
SELECT regexp_extract(str, pattern, 0) FROM t_largeutf8;
----
NULL
a
ABC
(empty)
(empty)
(empty)
(empty)
4010
Düsseldorf
Москва
Köln
إسرائيل

statement ok
DROP TABLE t_largeutf8;

# -----------------------------------------------------------------------
# Capture group index defaults to 1 when omitted.

query T
SELECT regexp_extract('100-200', '(\d+)-(\d+)');
----
100

# -----------------------------------------------------------------------
# Return value is NULL when any of the arguments are NULL

query T
SELECT regexp_extract(NULL, 'a');
----
NULL

query T
SELECT regexp_extract('a', NULL);
----
NULL

query T
SELECT regexp_extract('a', 'a', NULL);
----
NULL

# -----------------------------------------------------------------------
# All arguments are scalar.

query T
SELECT regexp_extract('abc', 'abc', 0) FROM regexp_test_data;
----
abc
abc
abc
abc
abc
abc
abc
abc
abc
abc
abc
abc

# -----------------------------------------------------------------------
# Error on invalid regex.

query error Regular expression did not compile: +
SELECT regexp_extract('bb-1', '+');

# -----------------------------------------------------------------------
# Error on negative capture group index.

query error regexp_extract idx -1 cannot be converted to usize
SELECT regexp_extract('ab', '(a)(b)', -1)

# -----------------------------------------------------------------------
# Error when capture group index does not exist.

query error regexp_extract idx is 3 but there are only 3 capture groups
SELECT regexp_extract('ab', '(a)(b)', 3)

query error regexp_extract idx is 1 but there are only 1 capture groups
SELECT regexp_extract('ab', 'ab')
