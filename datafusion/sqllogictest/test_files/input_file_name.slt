##########
## input_file_name() tests
##########

statement ok
COPY  (VALUES (10), (20), (30))
TO 'test_files/scratch/input_file_name/csv/first.csv'
STORED AS CSV;

statement ok
COPY  (VALUES (40), (50), (60))
TO 'test_files/scratch/input_file_name/csv/second.csv'
STORED AS CSV;

statement ok
CREATE EXTERNAL TABLE csv_table(column1 int)
STORED AS CSV
LOCATION 'test_files/scratch/input_file_name/csv/';

query TI
SELECT
  input_file_name(),
  column1
FROM csv_table
ORDER BY column1
