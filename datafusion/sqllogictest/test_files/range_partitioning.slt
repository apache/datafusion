##########
# TEST 24: Right Join on Non-Range Key Repartitions
# Both inputs expose Range([range_key]), but the join key is non_range_key.
# Range([range_key]) does not satisfy KeyPartitioned([non_range_key]), so
# planning inserts Hash repartitioning on the actual join key for the right join.
##########

query TT
EXPLAIN SELECT l.value, r.range_key, r.value
FROM (SELECT non_range_key, value FROM range_partitioned WHERE range_key < 10) l
RIGHT JOIN range_partitioned r ON l.non_range_key = r.non_range_key;
