# 2 Joins
query TT
EXPLAIN SELECT table1.string_col, table2.date_col
FROM table1 
JOIN table2 
ON 
  (table1.int_col = table2.int_col)
  AND (((table1.int_col + table2.int_col) % 2) = 0)
