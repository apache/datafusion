# Create table for InterleaveExec
statement ok
CREATE TABLE t1(
  id INT,
  name TEXT
) as VALUES
  (1, 'Alex'),
  (2, 'Bob'),
  (3, 'Alice')
;

statement ok
CREATE TABLE t2(
  id TINYINT,
  name TEXT
) as VALUES
  (1, 'Alex'),
  (2, 'Bob'),
  (3, 'John')
;

