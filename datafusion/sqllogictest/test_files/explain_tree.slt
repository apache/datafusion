# 3 Joins
query TT
explain SELECT
  table1.string_col,
  table2.date_col,
  table3.date_col
FROM
  table1 JOIN table2 ON table1.int_col = table2.int_col
         JOIN table3 ON table2.int_col = table3.int_col;
----
logical_plan
01)Projection: table1.string_col, table2.date_col, table3.date_col
02)--Inner Join: table2.int_col = table3.int_col
03)----Projection: table1.string_col, table2.int_col, table2.date_col
04)------Inner Join: table1.int_col = table2.int_col
05)--------TableScan: table1 projection=[int_col, string_col]
06)--------TableScan: table2 projection=[int_col, date_col]
07)----TableScan: table3 projection=[int_col, date_col]
physical_plan
01)в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
02)в”Ӯ    CoalesceBatchesExec    в”Ӯ
03)в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
04)в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
05)в”Ӯ        HashJoinExec       в”Ӯ
06)в”Ӯ    --------------------   в”Ӯ
07)в”Ӯ            on:            в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
08)в”Ӯ  (int_col@1 = int_col@0)  в”Ӯ                                           в”Ӯ
09)в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ                                           в”Ӯ
