20)│        format: csv        │
21)└───────────────────────────┘

# Aggregate
query TT
explain SELECT string_col, SUM(bigint_col) FROM table1 GROUP BY string_col;
----
logical_plan
01)┌───────────────────────────┐
02)│         Aggregate         │
03)│    --------------------   │
04)│      groupBy=[[table1     │
05)│       .string_col]],      │
06)│      aggr=[[sum(table1    │
07)│       .bigint_col)]]      │
08)└─────────────┬─────────────┘
09)┌─────────────┴─────────────┐
10)│         TableScan         │
11)│    --------------------   │
12)│     table1 projection=    │
13)│        [string_col,       │
14)│         bigint_col]       │
15)└───────────────────────────┘
physical_plan
