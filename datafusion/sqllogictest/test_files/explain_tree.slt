03)в”Ӯ    --------------------   в”Ӯ
04)в”Ӯ      groupBy=[[table1     в”Ӯ
05)в”Ӯ       .string_col]],      в”Ӯ
06)в”Ӯ      aggr=[[sum(table1    в”Ӯ
07)в”Ӯ       .bigint_col)]]      в”Ӯ
08)в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
