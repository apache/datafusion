2 1 NULL 1
4 2 NULL 1
7 2 NULL 2

# Test 25: ORDER BY val DESC NULLS FIRST (default for DESC) — NULLs first
query IIII rowsort
SELECT id, pk, val, rn FROM (
  SELECT *, ROW_NUMBER() OVER (PARTITION BY pk ORDER BY val DESC NULLS FIRST) as rn FROM window_topn_nulls
) WHERE rn <= 2;
