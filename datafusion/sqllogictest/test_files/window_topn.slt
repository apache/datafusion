5 2 5 1
6 2 15 2

# Test 24: ORDER BY val ASC NULLS FIRST — NULLs sorted first within partition
query IIII rowsort
SELECT id, pk, val, rn FROM (
  SELECT *, ROW_NUMBER() OVER (PARTITION BY pk ORDER BY val ASC NULLS FIRST) as rn FROM window_topn_nulls
) WHERE rn <= 2;
