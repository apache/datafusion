statement ok
SET datafusion.explain.physical_plan_only = true;

query TT
EXPLAIN SELECT * FROM (
  SELECT *, ROW_NUMBER() OVER (ORDER BY id) as rn FROM window_topn_t
) WHERE rn <= 3;
