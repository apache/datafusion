# Test 16: Multiple partition keys — should optimize
statement ok
SET datafusion.explain.physical_plan_only = true;

query TT
EXPLAIN SELECT * FROM (
  SELECT *, ROW_NUMBER() OVER (PARTITION BY pk, id ORDER BY val) as rn FROM window_topn_t
) WHERE rn <= 3;
