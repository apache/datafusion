# Test 26: ORDER BY val DESC NULLS LAST — NULLs last
query IIII rowsort
SELECT id, pk, val, rn FROM (
  SELECT *, ROW_NUMBER() OVER (PARTITION BY pk ORDER BY val DESC NULLS LAST) as rn FROM window_topn_nulls
) WHERE rn <= 2;
----
1 1 10 2
3 1 30 1
5 2 5 2
6 2 15 1

