# Regression test for row-valued NOT IN with a partially NULL tuple.
# This matches DuckDB issue #19182 and the Postgres-style behavior from
# https://github.com/duckdb/duckdb/pull/22683. It is commented out because
# tuple-valued NOT IN needs row-comparison NULL semantics that are outside this
# scalar null-aware mark join PR.
# query II rowsort
# SELECT f1, f2
# FROM outer_tuple_table
# WHERE (f1, f2) NOT IN (
#   SELECT c1, c2
#   FROM inner_tuple_table
# );
# ----
# 1 0
#
# query II rowsort
# SELECT f1, f2
# FROM outer_tuple_table
# WHERE ((f1, f2) NOT IN (
#   SELECT c1, c2
#   FROM inner_tuple_table
# )) IS NULL;
# ----
# 0 0

# These queries would fall back to a sort-merge, but we force them
# into hash joins to make sure we preserve null awareness.

statement ok
set datafusion.optimizer.prefer_hash_join = false;

query TT
EXPLAIN SELECT id, value
FROM outer_table
WHERE (id NOT IN (SELECT id FROM inner_table_with_null)) IS NULL;
----
logical_plan
01)Projection: outer_table.id, outer_table.value
02)--Filter: NOT __correlated_sq_1.mark IS NULL
03)----LeftMark Join: outer_table.id = __correlated_sq_1.id null_aware
04)------TableScan: outer_table projection=[id, value]
05)------SubqueryAlias: __correlated_sq_1
06)--------TableScan: inner_table_with_null projection=[id]
physical_plan
01)FilterExec: NOT mark@2 IS NULL, projection=[id@0, value@1]
02)--RepartitionExec: partitioning=RoundRobinBatch(2), input_partitions=1
03)----HashJoinExec: mode=CollectLeft, join_type=LeftMark, on=[(id@0, id@0)], null_aware
04)------DataSourceExec: partitions=1, partition_sizes=[1]
05)------DataSourceExec: partitions=1, partition_sizes=[1]

